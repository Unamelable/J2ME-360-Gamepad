<Window x:Class="J2MEGamepad.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="J2ME 360 Gamepad — CTRL+R to restart"
        Height="670"
        Width="690"
        Topmost="False"
        ShowActivated="False"
        Icon="pack://application:,,,/icon.ico">
    <Window.Resources>
        <Style TargetType="Border" x:Key="SectionBorder">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderBrush" Value="#ccc"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
    </Window.Resources>
    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource SectionBorder}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0"
                           x:Name="ControllerStatus"
                           Text="Waiting for controller..."
                           Foreground="Red"
                           FontWeight="Bold"
                           FontSize="14"
                           VerticalAlignment="Center"/>
                <CheckBox Grid.Row="1" Grid.Column="0"
                          x:Name="StartMinimizedCheckbox"
                          Content="Start minimized to tray"
                          VerticalAlignment="Center"
                          Margin="0,4,0,0"
                          Checked="StartMinimizedCheckbox_Changed"
                          Unchecked="StartMinimizedCheckbox_Changed"/>
                <CheckBox Grid.Row="2" Grid.Column="0"
                          x:Name="TerminateIfKemulatorClosedCheckbox"
                          Content="Terminate if KEmulator closed"
                          VerticalAlignment="Center"
                          Margin="0,2,0,0"
                          Checked="TerminateIfKemulatorClosed_Changed"
                          Unchecked="TerminateIfKemulatorClosed_Changed"/>
                <StackPanel Grid.Row="0" Grid.Column="1" Grid.RowSpan="3" Orientation="Vertical">
                    <Button x:Name="MinimizeToTrayButton"
                            Content="Minimize to Tray"
                            Width="120"
                            Margin="0,0,0,4"
                            Click="MinimizeToTray_Click"/>
                    <Button x:Name="KeysHintButton"
                            Content="Keys Reference"
                            Width="120"
                            Click="KeysHintButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource SectionBorder}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <TextBlock Text="DPAD Mode:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock x:Name="DpadModeText" Text="PAD Mode" FontSize="16" Foreground="DodgerBlue"/>
                    <CheckBox x:Name="BackCyclesCheckbox"
                              Content="View/Back cycles mapping layouts"
                              Margin="0,8,0,0"
                              Checked="BackCycles_Changed"
                              Unchecked="BackCycles_Changed"/>
                    <CheckBox x:Name="SkipDefaultCheckbox"
                              Content="Skip Default in cycling"
                              Margin="0,4,0,0"
                              IsEnabled="False"
                              Checked="SkipDefault_Changed"
                              Unchecked="SkipDefault_Changed"/>
                    <CheckBox x:Name="DisableComboModifierOSDCheckbox"
                              Content="Disable combo modifier OSD prompt"
                              Margin="0,4,0,0"
                              Checked="DisableComboModifierOSD_Changed"
                              Unchecked="DisableComboModifierOSD_Changed"/>
                    <CheckBox x:Name="ComboConfirmationHoldCheckbox"
                              Content="Confirmation combo-hold"
                              Margin="0,4,0,0"
                              Checked="ComboConfirmationHold_Changed"
                              Unchecked="ComboConfirmationHold_Changed"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Current Profile:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock x:Name="ProfileText" Text="Default" FontSize="16" Foreground="ForestGreen"/>
                    <Grid Margin="0,5,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Diagonal delay:" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Slider Grid.Column="1" x:Name="DiagDelaySlider"
                                Minimum="0" Maximum="300" SmallChange="10" LargeChange="50"
                                ValueChanged="DiagDelaySlider_ValueChanged"
                                TickFrequency="10" TickPlacement="None" Margin="0,0,6,0"/>
                        <TextBlock Grid.Column="2" x:Name="DiagDelayValue"
                                   Text="0" VerticalAlignment="Center" MinWidth="30"
                                   FontWeight="Bold" FontSize="14"/>
                    </Grid>
                    <Grid Margin="0,4,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Directional delay:" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Slider Grid.Column="1" x:Name="DirDelaySlider"
                                Minimum="0" Maximum="300" SmallChange="10" LargeChange="50"
                                ValueChanged="DirDelaySlider_ValueChanged"
                                TickFrequency="10" TickPlacement="None" Margin="0,0,6,0"/>
                        <TextBlock Grid.Column="2" x:Name="DirDelayValue"
                                   Text="0" VerticalAlignment="Center" MinWidth="30"
                                   FontWeight="Bold" FontSize="14"/>
                    </Grid>
                    <Grid Margin="0,4,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Combo activation delay:" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Slider Grid.Column="1" x:Name="ComboActDelaySlider"
                                Minimum="0" Maximum="500" SmallChange="10" LargeChange="50"
                                ValueChanged="ComboActDelaySlider_ValueChanged"
                                TickFrequency="10" TickPlacement="None" Margin="0,0,6,0"/>
                        <TextBlock Grid.Column="2" x:Name="ComboActDelayValue"
                                   Text="0" VerticalAlignment="Center" MinWidth="30"
                                   FontWeight="Bold" FontSize="14"/>
                    </Grid>
                    <CheckBox x:Name="DiagDelayHoldCheckbox"
                              Content="Hold cardinal keys during delay"
                              Margin="0,1,0,0"
                               IsChecked="False"
                              Checked="DiagDelayHold_Changed"
                              Unchecked="DiagDelayHold_Changed"/>
                    <CheckBox x:Name="DiagDelayPerProfileCheckbox"
                              Content="Save delay per profile (Unchecked = global)"
                              Margin="0,1,0,0"
                              Checked="DiagDelayPerProfile_Changed"
                              Unchecked="DiagDelayPerProfile_Changed"/>
                    <CheckBox x:Name="ComboPerProfileCheckbox"
                              Content="Save combo bindings per profile (Unchecked = global)"
                              Margin="0,1,0,0"
                              Checked="ComboPerProfile_Changed"
                              Unchecked="ComboPerProfile_Changed"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource SectionBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="Profiles" FontWeight="Bold" FontSize="14"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Button Name="NewProfileButton" Content="New" Width="50" Margin="2,0" Click="NewProfile_Click"/>
                    <Button Name="DeleteProfileButton" Content="Delete" Width="55" Margin="2,0" Click="DeleteProfile_Click"/>
                    <Button Name="ConfigFolderButton" Content="Config Folder" Width="95" Margin="2,0" Click="OpenConfigFolder_Click"/>
                </StackPanel>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="155"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="150"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" Margin="0,0,8,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Select gamepad button to remap:" FontWeight="Bold" Margin="0,0,0,5"
                                   TextWrapping="Wrap"/>
                        <ListBox Grid.Row="1" x:Name="KeyListBox"
                                  SelectionChanged="KeyListBox_SelectionChanged">
                            <ListBoxItem Tag="Y">Y Button</ListBoxItem>
                            <ListBoxItem Tag="X">X Button</ListBoxItem>
                            <ListBoxItem Tag="A">A Button</ListBoxItem>
                            <ListBoxItem Tag="B">B Button</ListBoxItem>
                            <ListBoxItem Tag="LB">LB</ListBoxItem>
                            <ListBoxItem Tag="RB">RB</ListBoxItem>
                            <ListBoxItem Tag="LT">LT</ListBoxItem>
                            <ListBoxItem Tag="RT">RT</ListBoxItem>
                            <ListBoxItem Tag="RightThumb">Right Stick Button</ListBoxItem>
                            <ListBoxItem Tag="LeftThumb">Left Stick Button</ListBoxItem>
                            <ListBoxItem Tag="Back" Visibility="Collapsed" Name="DInputBackItem">SELECT (Back)</ListBoxItem>
                            <ListBoxItem Tag="Start" Visibility="Collapsed" Name="DInputStartItem">START</ListBoxItem>
                            <ListBoxItem Tag="DPadUp" Visibility="Collapsed" Name="DInputDpadUpItem">D-Pad Up</ListBoxItem>
                            <ListBoxItem Tag="DPadDown" Visibility="Collapsed" Name="DInputDpadDownItem">D-Pad Down</ListBoxItem>
                            <ListBoxItem Tag="DPadLeft" Visibility="Collapsed" Name="DInputDpadLeftItem">D-Pad Left</ListBoxItem>
                            <ListBoxItem Tag="DPadRight" Visibility="Collapsed" Name="DInputDpadRightItem">D-Pad Right</ListBoxItem>
                            <ListBoxItem IsEnabled="False" FontWeight="Bold" Foreground="Gray">── Combos ──</ListBoxItem>
                            <ListBoxItem Tag="RB+LB+Y">RB+LB → Y</ListBoxItem>
                            <ListBoxItem Tag="RB+LB+X">RB+LB → X</ListBoxItem>
                            <ListBoxItem Tag="RB+LB+A">RB+LB → A</ListBoxItem>
                            <ListBoxItem Tag="RB+LB+B">RB+LB → B</ListBoxItem>
                            <ListBoxItem Tag="RT+LT+Y">RT+LT → Y</ListBoxItem>
                            <ListBoxItem Tag="RT+LT+X">RT+LT → X</ListBoxItem>
                            <ListBoxItem Tag="RT+LT+A">RT+LT → A</ListBoxItem>
                            <ListBoxItem Tag="RT+LT+B">RT+LT → B</ListBoxItem>
                            <ListBoxItem Tag="RSB+Y">RSB → Y</ListBoxItem>
                            <ListBoxItem Tag="RSB+X">RSB → X</ListBoxItem>
                            <ListBoxItem Tag="RSB+A">RSB → A</ListBoxItem>
                            <ListBoxItem Tag="RSB+B">RSB → B</ListBoxItem>
                            <ListBoxItem Tag="LSB+Y">LSB → Y</ListBoxItem>
                            <ListBoxItem Tag="LSB+X">LSB → X</ListBoxItem>
                            <ListBoxItem Tag="LSB+A">LSB → A</ListBoxItem>
                            <ListBoxItem Tag="LSB+B">LSB → B</ListBoxItem>
                            <ListBoxItem IsEnabled="False" FontWeight="Bold" Foreground="Gray">── Combo-Exec ──</ListBoxItem>
                            <ListBoxItem Tag="RB+LB+Start">RB+LB → Start</ListBoxItem>
                            <ListBoxItem Tag="RB+LB+Back">RB+LB → Back</ListBoxItem>
                            <ListBoxItem Tag="RT+LT+Start">RT+LT → Start</ListBoxItem>
                            <ListBoxItem Tag="RT+LT+Back">RT+LT → Back</ListBoxItem>
                        </ListBox>
                    </Grid>
                    <Grid Grid.Column="1" Margin="0,0,8,0" VerticalAlignment="Top">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Current mapping:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <Border Grid.Row="1" BorderBrush="#888" BorderThickness="1" CornerRadius="4"
                                Padding="15,8" Background="#f5f5f5">
                            <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Image x:Name="ExecIconImage" Width="24" Height="24"
                                           Margin="0,0,6,0" Visibility="Collapsed"/>
                                    <TextBlock x:Name="CurrentMappingText" Text="(none selected)"
                                               FontSize="24" FontWeight="Bold"/>
                                </StackPanel>
                            </Viewbox>
                        </Border>
                        <TextBlock Grid.Row="2" Text="Press a key on keyboard to assign:" Margin="0,10,0,3"/>
                        <Border Grid.Row="3" x:Name="KeyCaptureBox"
                                BorderBrush="#aaa" BorderThickness="2"
                                CornerRadius="4" Padding="10,6"
                                Background="#eee"
                                MinHeight="36"
                                MouseDown="KeyCaptureBox_MouseDown"
                                IsEnabled="False">
                            <TextBlock x:Name="KeyCaptureText"
                                       Text="Click to capture"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="15"/>
                        </Border>
                        <CheckBox Grid.Row="4" x:Name="IsDefaultCheckbox" Content="Use default mapping"
                                  Margin="0,8,0,0"
                                  Checked="IsDefaultCheckbox_Changed"
                                  Unchecked="IsDefaultCheckbox_Changed"/>
                        <StackPanel Grid.Row="4" x:Name="ComboControlPanel"
                                    Visibility="Collapsed" Margin="0,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="OSD name:" FontWeight="Bold"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBox Grid.Column="1" x:Name="ComboOSDNameBox" Text="" MaxLength="30"
                                          ToolTip="Enter the OSD display name for this combo"
                                          TextChanged="ComboOSDNameBox_TextChanged"
                                          LostFocus="ComboOSDNameBox_LostFocus"/>
                                <Button Grid.Column="2" x:Name="ClearComboButton"
                                        Content="Clear"
                                        Padding="6,2"
                                        Margin="4,0,0,0"
                                        Click="ClearComboButton_Click"/>
                            </Grid>
                            <Grid x:Name="ExecPathPanel" Visibility="Collapsed" Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" x:Name="ExecPathBox" Text=""
                                         ToolTip="Path to executable (.exe, .bat, .ps1)"
                                         TextChanged="ExecPathBox_TextChanged"/>
                                <Button Grid.Column="1" x:Name="BrowseExecButton"
                                        Content="Browse..."
                                        Padding="6,2" Margin="4,0"
                                        Click="BrowseExecButton_Click"/>
                                <Button Grid.Column="2" x:Name="OpenExecButton"
                                        Content="Open"
                                        Padding="6,2"
                                        Click="OpenExecButton_Click"/>
                            </Grid>
                        </StackPanel>
                        <CheckBox Grid.Row="5" x:Name="ThumbComboModifierCheckbox"
                                  Content="Is a combo-modifier"
                                  Margin="0,8,0,0"
                                  Visibility="Collapsed"
                                  Checked="ThumbComboModifierCheckbox_Changed"
                                  Unchecked="ThumbComboModifierCheckbox_Changed"/>
                        <StackPanel Grid.Row="6" x:Name="ThumbWarningPanel"
                                    Visibility="Collapsed" Margin="0,8,0,0">
                            <TextBlock x:Name="LeftThumbWarningText"
                                       TextWrapping="Wrap"
                                       Foreground="Red"
                                       FontWeight="Bold"
                                       FontSize="11"
                                       Margin="0,0,0,4"
                                       Text="This button is assigned to &quot;backcycles&quot;. If a key is assigned here, the backcycle function will be disabled!"/>
                            <TextBlock x:Name="RightThumbWarningText"
                                       TextWrapping="Wrap"
                                       Foreground="Red"
                                       FontWeight="Bold"
                                       FontSize="11"
                                       Text="The default behavior of RSB is to send F3 (PAD mode) or Numpad_5 (KEYPAD/PAD+DIAGONAL mode)."/>
                        </StackPanel>
                        <StackPanel Grid.Row="7" x:Name="DInputActionPanel"
                                    Visibility="Collapsed" Margin="0,8,0,0">
                            <TextBlock Text="DInput actions:" FontWeight="Bold" Margin="0,0,0,4"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" x:Name="DInputRemapButton"
                                         Content="Remap button"
                                         Padding="4,3" Margin="0,0,3,0"
                                         Click="DInputRemapButton_Click"/>
                                <Button Grid.Column="1" x:Name="CalibrateDpadButton"
                                        Content="Calibrate D-Pad"
                                        Padding="4,3" Margin="3,0,0,0"
                                        Click="CalibrateDpadButton_Click"/>
                            </Grid>
                        </StackPanel>
                        <StackPanel Grid.Row="8" x:Name="DInputDeadzonePanel"
                                    Visibility="Collapsed" Margin="0,8,0,0">
                            <TextBlock Text="DInput deadzone:" FontWeight="Bold" Margin="0,0,0,3"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Slider Grid.Column="0" x:Name="DInputDeadzoneSlider"
                                        Minimum="10" Maximum="80" SmallChange="5" LargeChange="10"
                                        ValueChanged="DInputDeadzoneSlider_ValueChanged"
                                        Margin="0,0,6,0"/>
                                <TextBlock Grid.Column="1" x:Name="DInputDeadzoneValue"
                                           Text="40%" VerticalAlignment="Center"
                                           FontWeight="Bold" MinWidth="35"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Profile name:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox Grid.Row="1" x:Name="ProfileNameBox" Text="" Margin="0,0,0,8" MaxLength="18"
                                 KeyDown="ProfileNameBox_KeyDown" LostFocus="ProfileNameBox_LostFocus"/>
                        <TextBlock Grid.Row="2" Text="Profile list:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <ListBox Grid.Row="3" x:Name="ProfileListBox"
                                 SelectionChanged="ProfileListBox_SelectionChanged"/>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
